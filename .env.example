# ============================================================
# Hermes 环境变量模板
# 复制此文件为 .env 并填入你的值
# 绝对不要将 .env 提交到版本控制
#
# Hermes 会按以下优先级加载环境变量（高 -> 低）：
# 1. 已导出的进程环境变量
# 2. Hermes 自身的 .env 文件
# 3. 主仓库的 .env 文件（/workspace/.env 与 /workspace/OpenClaw/openclaw-main/.env）
# 4. 默认值
#
# 所有用户可写状态均放在项目目录内（.state / .cache / logs），
# 避免写入沙盒限制的目录（如 ~/.xxx）。
# ============================================================

# ---------------------------------------------------------------------------
# Hermes 自身配置
# ---------------------------------------------------------------------------
HERMES_LOG_LEVEL=INFO
HERMES_MAIN_REPO_PATH=/workspace/OpenClaw/openclaw-main
# HERMES_STATE_DIR=./.state
# HERMES_CACHE_DIR=./.cache

# ---------------------------------------------------------------------------
# OpenClaw 网关与模型（继承自主仓库）
# ---------------------------------------------------------------------------
OPENCLAW_LLM_API_KEY=
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_GATEWAY_PASSWORD=
# OPENCLAW_STATE_DIR=
# OPENCLAW_CONFIG_PATH=

OPENCLAW_MODEL_PRIMARY=anthropic/claude-sonnet-4-5
OPENCLAW_MODEL_FALLBACK=openai/gpt-4o

# ---------------------------------------------------------------------------
# 模型提供商 API 密钥
# 主流厂商（至少配置一个）
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 国内/区域厂商
# MOONSHOT_API_KEY=              # Kimi (Moonshot AI)
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# ZAI_API_KEY=                   # 智谱 GLM / z.ai
# ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# QIANFAN_ACCESS_KEY=            # 百度千帆
# QIANFAN_SECRET_KEY=
# DASHSCOPE_API_KEY=             # 阿里通义千问 / Qwen
# XIAOMI_API_KEY=                # 小米 MiMo
# MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=
# MISTRAL_API_KEY=
# NOVITA_API_KEY=
# NOVITA_BASE_URL=https://api.novita.ai/v3/openai

# 本地 / OpenAI 兼容端点
# OLLAMA_BASE_URL=http://localhost:11434/v1
# MODELSCOPE_API_KEY=            # ModelScope 魔搭（OpenAI 兼容）
# MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

