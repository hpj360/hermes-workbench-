    "red":    { "500": "#EF4444", "600": "#DC2626" },
    "green":  { "500": "#10B981", "600": "#059669" },
    "yellow": { "500": "#F59E0B" }
  },
  "font": {
    "family": { "sans": "Inter, system-ui, sans-serif", "mono": "JetBrains Mono, monospace" },
